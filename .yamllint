---
extends: default

rules:
  line-length:
    max: 200
    level: warning
  document-start: disable
  truthy:
    check-keys: false
  comments:
    min-spaces-from-content: 1
  indentation:
    spaces: 2
    indent-sequences: consistent
  braces:
    max-spaces-inside: 1

ignore: |
  .venv-default/
  dist/
  function/proto/
  htmlcov/
  .task/
